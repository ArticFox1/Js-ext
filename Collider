(function (Scratch) {
  "use strict";
  //Variables
  const isPen = Scratch.extensions.isPenguinMod;
  const vm = Scratch.vm
  const runtime = vm.runtime
  if (!Scratch.extensions.unsandboxed) {
    throw new Error("Must be ran unsandboxed!!!")
  }
  const menuIcon = "data:image/svg+xml;base64,"
  //Functions
  function dist() {
    
  }
  //Extension Class
  class Extension {
    getInfo() {
        return {
        id: "collide",
        name: "Colliders",
        color1: "#1a98ff",
        menuIconURI: menuIcon,
        blocks: [
            //Declarations
            {
                opcode: "extCircle",
                text: "create circle at x:[X] y:[Y] with radius:[R]",
                disableMonitor: true,
                blockType: Scratch.BlockType.REPORTER,
                blockShape: Scratch.BlockShape.PLUS,
                allowDropAnywhere: false,
                arguments: {
                    X: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true },
                    Y: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true },
                    R: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true, defaultValue: 20 }
                }
            },
            {
                opcode: "extBox",
                text: "create box at x:[X] y:[Y] rounded to:[R]px in direction:[A]",
                disableMonitor: true,
                blockType: Scratch.BlockType.REPORTER,
                blockShape: Scratch.BlockShape.PLUS,
                allowDropAnywhere: false,
                arguments: {
                    X: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true },
                    Y: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true },
                    R: { type: Scratch.ArgumentType.NUMBER, exemptFromNormalization: true },
                    A: { type: Scratch.ArgumentType.ANGLE, exemptFromNormalization: true, defaultValue: 90 }
                }
            },
